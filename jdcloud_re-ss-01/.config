# ======================
# 1. 核心目标平台（必须）
# ======================
CONFIG_TARGET_qualcommax=y
CONFIG_TARGET_qualcommax_ipq60xx=y
CONFIG_TARGET_qualcommax_ipq60xx_DEVICE_jdcloud_re-ss-01=y

# 16MB SPI 安全分区限制
CONFIG_TARGET_SQUASHFS=y
CONFIG_TARGET_ROOTFS_PARTSIZE=12
# CONFIG_TARGET_EXT4 is not set
# CONFIG_TARGET_EXT4_FS is not set

# ======================
# 2. 基础系统组件（仅保留最低运行环境）
# ======================
CONFIG_BUSYBOX_DEFAULT_FEATURES=y
CONFIG_LIBC_USE_GLIBC=y
CONFIG_BUSYBOX_CONFIG_FEATURE_SH_IS_ASH=y
CONFIG_BUSYBOX_CONFIG_FEATURE_EDITING=y
CONFIG_BUSYBOX_CONFIG_FEATURE_EDITING_HISTORY=y

# ======================
# 3. IPv6 强制保留（按你的要求）
# ======================
CONFIG_IPV6=y
CONFIG_PACKAGE_ipv6helper=y

# ======================
# 4. 必须硬件驱动（一个都不能少）
# ======================
# Wi-Fi 6 驱动
CONFIG_PACKAGE_kmod-ath11k=y
CONFIG_PACKAGE_kmod-ath11k-pci=y
CONFIG_PACKAGE_wpad-basic-mbedtls=y

# EMMC 驱动（识别内置存储）
CONFIG_PACKAGE_kmod-mmc=y
CONFIG_PACKAGE_kmod-mmc-spi=y

# NSS 网络加速（核心性能）
CONFIG_PACKAGE_kmod-qca-nss-drv=y
CONFIG_PACKAGE_kmod-qca-nss-ecm=y

# ======================
# 5. 网络与SSH（必须，无LuCI也能远程管理）
# ======================
CONFIG_PACKAGE_dropbear=y          # SSH服务，必选
CONFIG_PACKAGE_opkg=y              # 包管理器，后续装工具用，必选
CONFIG_PACKAGE_opkg-core=y
CONFIG_PACKAGE_iptables=y          # 基础防火墙（路由必备）
CONFIG_PACKAGE_ip6tables=y         # IPv6防火墙（必选）

# ======================
# 6. 【全部禁用】非必要组件（关键！控体积）
# ======================
# 禁用所有LuCI（完全砍掉Web界面，省2~3MB空间）
# CONFIG_PACKAGE_luci is not set
# CONFIG_PACKAGE_luci-mod-admin-full is not set
# CONFIG_PACKAGE_luci-theme-bootstrap is not set
# CONFIG_LUCI_LANG_zh-cn is not set
# CONFIG_PACKAGE_luci-app-* 全部禁用

# 禁用所有工具类（fdisk、mkfs.ext4等，后续联网安装）
# CONFIG_PACKAGE_fdisk is not set
# CONFIG_PACKAGE_mkfs.ext4 is not set
# CONFIG_PACKAGE_e2fsprogs is not set
# CONFIG_PACKAGE_tar is not set
# CONFIG_PACKAGE_gzip is not set

# 禁用USB/蓝牙/存储扩展
# CONFIG_PACKAGE_usb-support is not set
# CONFIG_PACKAGE_kmod-usb-core is not set
# CONFIG_PACKAGE_kmod-usb-storage is not set
# CONFIG_PACKAGE_kmod-bluetooth is not set

# 禁用Docker/容器相关
# CONFIG_PACKAGE_docker is not set
# CONFIG_PACKAGE_kmod-docker is not set

# 禁用内核调试/日志（省空间，不影响稳定性）
# CONFIG_KERNEL_DEBUG is not set
# CONFIG_KERNEL_PRINTK is not set
# CONFIG_PACKAGE_logd is not set

# 禁用OpenSSH（用dropbear替代，省空间）
# CONFIG_PACKAGE_openssh-server is not set
# CONFIG_PACKAGE_openssh-sftp-server is not set

# 禁用多语言/国际化（仅保留系统基础语言）
# CONFIG_LUCI_LANG_en is not set
# CONFIG_LUCI_LANG_zh-tw is not set

# 禁用性能监控/流量统计
# CONFIG_PACKAGE_iperf3 is not set
# CONFIG_PACKAGE_vnstat is not set

# 禁用所有网络附加功能（UPnP/DDNS等）
# CONFIG_PACKAGE_upnp is not set
# CONFIG_PACKAGE_ddns-scripts is not set
